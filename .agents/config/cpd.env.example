# Copy to cpd.env and fill in. cpd.env is gitignored — never commit it.
#
#   cp .agents/config/cpd.env.example .agents/config/cpd.env

# --- guitars API deploy ---
GUITARS_S3_BUCKET=wbits-go-lambda-code
GUITARS_STACK_NAME=guitars
GUITARS_AWS_REGION=eu-central-1

# --- guitars-webapp deploy ---
WEBAPP_BUCKET=your-guitars-webapp-bucket
WEBAPP_DIST=your-cloudfront-distribution-id
WEBAPP_AWS_REGION=eu-central-1

# Vite build-time vars (webapp)
VITE_GUITARS_API_BASE_URL=https://your-api.example.com
VITE_COGNITO_REGION=eu-central-1
VITE_COGNITO_USER_POOL_ID=eu-central-1_XXXXX
VITE_COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
